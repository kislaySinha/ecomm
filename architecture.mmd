%% ==========================================
%% CONNECTIONS
%% ==========================================

%% --- Client → Edge ---
    C1 & C2 -->|HTTPS| WAF
    WAF --> CDN
    CDN -->|static| S3FE
    CDN -->|API calls| ALB

%% --- Gateway ---
    ALB --> GW1 & GW2
    GW1 & GW2 <-..->|validate / blacklist| TokenRedis

%% --- Gateway → Services ---
    GW1 & GW2 --> AuthSvc
    GW1 & GW2 --> SearchSvc
    GW1 & GW2 --> ProdSvc
    GW1 & GW2 --> AdminSvc
    GW1 & GW2 --> CartSvc
    GW1 & GW2 --> CoSvc
    GW1 & GW2 --> OrderSvc

%% --- Auth ---
    AuthSvc --> AuthDB

%% --- Search ---
    SearchSvc --> SearchRedis
    SearchSvc --> Elastic

%% --- Product ---
    ProdSvc --> ProdDB
    ProdSvc -.->|read| ProdReplica
    ProdSvc --> S3Img
    AdminSvc -->|CRUD| ProdSvc

%% --- Cart ---
    CartSvc --> CartRedis

%% --- Checkout Saga Steps ---
    CoSvc --> IdempRedis
    CoSvc -->|"① Lock"| LockRedis
    CoSvc -->|"② Reserve Stock"| InvSvc
    CoSvc -->|"③ Create Order"| OrderSvc
    CoSvc -->|"④ Charge"| PaySvc
    CoSvc -->|"⑤ Clear Cart"| CartSvc

%% --- Saga Compensation ---
    CoSvc -->|"⚠️ Rollback"| T_COMP
    T_COMP --> StockC
    T_COMP --> CartC

%% --- Order ---
    OrderSvc --> OrderDB
    OrderSvc -.->|read| OrderReplica
    OrderSvc --> T_ORD

%% --- Inventory ---
    InvSvc --> InvRedis
    InvSvc --> InvDB

%% --- Payment ---
    PaySvc --> PayDB
    PaySvc -->|charge| PayGW
    PaySvc -->|✅ success| T_PAY_OK
    PaySvc -->|❌ failure| T_PAY_FAIL

%% --- Inventory events ---
    InvSvc --> T_INV

%% --- DLQ fallback ---
    T_ORD & T_PAY_OK & T_PAY_FAIL & T_INV -.->|on failure| T_DLQ

%% --- Consumers subscribe ---
    T_PAY_OK --> StockC & CartC & NotifC
    T_PAY_FAIL --> NotifC
    T_INV --> CDCC

%% --- Consumers → Services ---
    StockC -->|update qty| InvSvc
    CartC -->|clear cart| CartSvc
    NotifC --> NotifSvc
    CDCC -->|sync index| Elastic

%% --- Notifications ---
    NotifSvc --> EmailCh & SMSCh

%% --- Observability (all services report via sidecar agents, not shown for clarity) ---


